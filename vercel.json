{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/manuelrevuelto.com/browser",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/manuelrevuelto.com/server/server.mjs",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/content/(.*)",
      "dest": "dist/manuelrevuelto.com/browser/content/$1"
    },
    {
      "src": "/(.*)",
      "dest": "dist/manuelrevuelto.com/server/server.mjs"
    }
  ]
}
