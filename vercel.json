{
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist/manuelrevuelto.com/browser",
  "framework": null,
  "functions": {
    "api/handler.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/handler.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
    },
    {
      "src": "/(.*)",
      "dest": "api/handler.js"
    }
  ]
}
