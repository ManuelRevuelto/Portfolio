{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/manuelrevuelto.com",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/manuelrevuelto.com/server/server.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "dist/manuelrevuelto.com/server/server.mjs"
    }
  ]
}
